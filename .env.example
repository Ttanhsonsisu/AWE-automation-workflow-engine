# GLOBAL ENVIRONMENT
# develop | staging | production
ASPNETCORE_ENVIRONMENT=develop

# DOCKER / HOST CONFIG
# use for docker-compose port mapping
API_GATEWAY_HTTP_PORT=8080
API_GATEWAY_HTTPS_PORT=8443

RABBITMQ_AMQP_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673

# RABBITMQ CORE CONFIG
RABBITMQ_DEFAULT_USER=awe-service
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_DEFAULT_VHOST=awe-system

# DATABASE POSTGRESQL
POSTGRES_IMAGE_TAG=18.1-alpine
POSTGRES_USER=awe_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=15432

# RABBITMQ CONNECTION (FOR SERVICES)
# Used inside docker-compose for services to find RabbitMQ
RABBITMQ_IMAGE_TAG=4.0-management
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=awe-service
RABBITMQ_PASSWORD=change_me
RABBITMQ_VHOST=awe-system

# MASS TRANSIT CONFIG
# retry policy
MT_RETRY_COUNT=5
MT_RETRY_INTERVAL_SECONDS=10

# prefetch
MT_PREFETCH_COUNT=16

# concurrency
MT_CONCURRENT_MESSAGE_LIMIT=8

# WORKFLOW ENGINE
WORKFLOW_ENGINE_NAME=AWE
WORKFLOW_ENGINE_INSTANCE_ID=local-dev-01

# OBSERVABILITY (OPTIONAL)
ENABLE_METRICS=true
ENABLE_HEALTHCHECK=true

# SECURITY / AUTH (PLACEHOLDER)
JWT_ISSUER=https://awe.local
JWT_AUDIENCE=awe-clients
JWT_SIGNING_KEY=change_me

# MINIO OBJECT STORAGE
MINIO_ROOT_USER=awe-service
MINIO_ROOT_PASSWORD=change_me
MINIO_PORT=9000
MINIO_MANAGEMENT_PORT=9001
