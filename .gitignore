# =======================================================
# .NET GITIGNORE
# Project: AWE (Automation Workflow Engine)
# =======================================================

# -------------------------------------------------------------------------
# 1. .NET & VISUAL STUDIO (CORE)
# -------------------------------------------------------------------------
# Build results
[Bb]in/
[Oo]bj/
.config/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
.artifacts/

# Generated files
[Gg]enerated_files/
[Pp]rofiles/

# -------------------------------------------------------------------------
# 2. .NET CORE & ASPIRE SPECIFIC
# -------------------------------------------------------------------------
# User Secrets (Critical security)
secrets.json
**/secrets.json
**/*.secrets.json

# Local Configuration (Overrides)
appsettings.Local.json
appsettings.Development.local.json

# Entity Framework Core Migration XMLs (if generated as artifacts)
*.edmx

# -------------------------------------------------------------------------
# 3. WEB FRONTEND (REACT / NODEJS)
# -------------------------------------------------------------------------
# Dependencies
**/node_modules/

# Production build artifacts
**/dist/
**/build/
**/out/

# Local Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------------------------------------------------------
# 4. TESTING & COVERAGE
# -------------------------------------------------------------------------
TestResults/
xunit_tests.html
coverage/
*.coverage
*.coveragexml

# -------------------------------------------------------------------------
# 5. IDEs & EDITORS
# -------------------------------------------------------------------------
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains Rider / IntelliJ
.idea/
*.sln.iml

# -------------------------------------------------------------------------
# 6. OPERATING SYSTEM FILES
# -------------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# -------------------------------------------------------------------------
# 7. SECURITY & CERTIFICATES
# -------------------------------------------------------------------------
# WARNING: Never commit private keys to the repo.
# Use Azure KeyVault, AWS Secrets Manager, or CI/CD variables instead.
*.pfx
*.p12
*.pem
*.key
*.asc

# Exception: If you explicitly want to commit Development certs (not recommended for Prod)
# !aspnetapp.pfx

# -------------------------------------------------------------------------
# 8. DOCKER & CONTAINERS
# -------------------------------------------------------------------------
# Local override file (contains local secrets/ports)
docker-compose.override.yml

# Docker build logs/artifacts if any
.docker/

# Docker runtime junk
**/.docker/
**/*.pid

# -------------------------------------------------------------------------
# 9. MISCELLANEOUS / LOGS
# -------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.old
*.orig

# Application specific uploads (if running locally)
wwwroot/uploads/
App_Data/
.github/
# ENV & SECRETS
.env
.env.*
!.env.example

# APPSETTINGS
**/appsettings.Development.json
**/appsettings.Staging.json
**/appsettings.Production.json
**/PublishProfiles
